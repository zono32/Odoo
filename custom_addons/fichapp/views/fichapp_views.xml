<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fichapp_landing_page" model="ir.ui.view">
        <field name="name">fichapp.landing.page</field>
        <field name="model">res.users</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <form string="Fichapp" create="false" edit="false" delete="false" class="o_fichapp_full_screen">
                <style>
                    /* Fuerza el ancho total rompiendo el contenedor de Odoo */
                    .o_content > .o_form_view.o_fichapp_full_screen {
                    padding: 0 !important;
                    }
                    .o_form_view.o_fichapp_full_screen .o_form_sheet_bg {
                    max-width: 100% !important;
                    width: 100% !important;
                    padding: 0 !important;
                    background: none !important;
                    border: none !important;
                    }
                    .o_form_view.o_fichapp_full_screen .o_form_sheet {
                    max-width: 100% !important;
                    width: 100% !important;
                    margin: 0 !important;
                    padding: 0 !important;
                    border: none !important;
                    box-shadow: none !important;
                    min-height: 100vh !important;
                    }
                    .sidebar_custom {
                    background-color: #f8f9fa !important;
                    border-left: 1px solid #dee2e6 !important;
                    min-height: 100vh;
                    }

                </style>

                <sheet>
                    <div class="container-fluid p-0">
                        <div class="row no-gutters" style="min-height: 100vh;">

                            <div class="col-xl-9 col-lg-8 p-5 bg-white">
                                <div class="row align-items-center shadow-sm p-4 bg-white rounded border" style="min-height: 250px;">
                                    <div class="col-md-8">
                                        <h1 style="color: #003b5c; font-weight: bold; font-size: 3.5em;">Acceso
                                            a Fichapp</h1>

                                        <div style="font-size: 1.3em; color: #555; margin-top: 25px; line-height: 1.6;">
                                            <p>
                                                Bienvenido a su portal centralizado de Fichapp.
                                                Desde aquí puede acceder a nuestra plataforma
                                                externa
                                                para gestionar su jornada laboral al completo, desde
                                                el registro preciso de entradas y salidas hasta
                                                la solicitud y seguimiento de sus vacaciones y
                                                ausencias.
                                            </p>
                                            <p style="font-size: 0.9em; opacity: 0.8; margin-top: 15px;">
                                                <i class="fa fa-refresh mr-2" />
                                                Toda su información
                                                está sincronizada en tiempo real con los módulos de
                                                RRHH de la compañía. </p>
                                            <div class="alert alert-info d-inline-flex align-items-center mt-3" style="border-radius: 50px; padding: 10px 30px;">
                                                <i class="fa fa-lock fa-lg mr-3" /><strong> Importante: </strong>&amp;nbsp; Consulte credenciales con su responsable. 
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4 text-center">
                                        <a href="https://fichapp.vercel.app/" target="_blank" class="btn btn-primary btn-lg" style="background-color: #003b5c; border: none; padding: 30px; font-size: 1.8em; width: 100%; border-radius: 12px; color: white; text-decoration: none; display: block; box-shadow: 0 10px 20px rgba(0,59,92,0.2);">
                                            <i class="fa fa-external-link-square mr-2" />
                                            Abrir Fichapp </a>
                                    </div>
                                </div>

                                <div class="row mt-5 pt-5 text-center">
                                    <div class="col-md-4">
                                        <i class="fa fa-clock-o mb-3" style="font-size: 4.5em; color: #003b5c;" />
                                        <h3 class="font-weight-bold">Fichajes</h3>
                                        <p class="text-muted small">Registro de entradas y salidas.</p>
                                    </div>
                                    <div class="col-md-4 border-left border-right">
                                        <i class="fa fa-calendar-check-o mb-3" style="font-size: 4.5em; color: #003b5c;" />
                                        <h3 class="font-weight-bold">Vacaciones</h3>
                                        <p class="text-muted small">Solicitud y control de
                                            ausencias.</p>
                                    </div>
                                    <div class="col-md-4">
                                        <i class="fa fa-id-card-o mb-3" style="font-size: 4.5em; color: #003b5c;" />
                                        <h3 class="font-weight-bold">Contratos</h3>
                                        <p class="text-muted small">Documentos y firmas legales.</p>
                                    </div>
                                </div>
                            </div>

                            <div class="col-xl-3 col-lg-4 sidebar_custom p-5 text-center">
                                <div class="mb-5 p-4 rounded bg-white border shadow-sm w-100">
                                    <div id="fichapp_clock" style="font-size: 2.8em; font-weight: bold; color: #003b5c;">
                                        00:00:00</div>
                                    <div id="fichapp_date" style="color: #888; text-transform: capitalize;">Cargando...</div>
                                </div>

                                <div class="d-flex align-items-center mb-4 text-left w-100">
                                    <field name="emp_image" widget="image" class="mr-4" readonly="1" options="{'size': [80, 80]}" style="border-radius: 90%; box-shadow: 0 4px 8px rgba(0,0,0,0.4); margin-right: 30px !important;" />
                                    <div class="overflow-hidden">
                                        <h3 class="font-weight-bold m-0 mt-1 text-truncate" style="color: #003b5c; font-size: 1.4em;">
                                            Hola, <field name="employee_id" readonly="1" />
                                        </h3>
                                        <div class="text-muted mt-1 text-truncate" style="font-size: 0.95em;">
                                            <field name="emp_job" readonly="1" />
                                        </div>
                                    </div>
                                </div>

                                <div class="mt-4 pt-4 border-top text-left w-100">
                                    <div class="mb-3 d-flex align-items-center">
                                        <i class="fa fa-phone mr-3" style="color: #003b5c; width: 20px;" />
                                        <strong>
                                            <field name="emp_phone" readonly="1" />
                                        </strong>
                                    </div>
                                    <div class="mb-3 d-flex align-items-center">
                                        <i class="fa fa-envelope mr-3" style="color: #003b5c; width: 20px;" />
                                        <span class="text-truncate">
                                            <strong>
                                                <field name="login" readonly="1" />
                                            </strong>
                                        </span>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fichapp_server_view" model="ir.actions.server">
        <field name="name">Mi Panel Fichapp</field>
        <field name="model_id" ref="base.model_res_users" />
        <field name="state">code</field>
        <field name="code">
            action = {
                'name': 'Mi Panel Fichapp',
                'type': 'ir.actions.act_window',
                'res_model': 'res.users',
                'view_mode': 'form',
                'res_id': env.user.id,
                'views': [(env.ref('fichapp.view_fichapp_landing_page').id, 'form')],
                'target': 'current',
            }
        </field>
    </record>

    <menuitem id="menu_fichapp_root" name="Fichapp" action="action_fichapp_server_view" sequence="1" />
</odoo>
<odoo>
  <data>
    <record id="view_school_student_search" model="ir.ui.view">
      <field name="name">school.student.search</field>
      <field name="model">school.student</field>
      <field name="arch" type="xml">
        <search string="Buscar Estudiantes">
          <field name="name" />
          <field name="grade" />
          <filter string="Mayores de edad" name="adults" domain="[('age', '>=', 18)]" />
          <group>
            <filter string="Grado" name="group_by_grade" context="{'group_by': 'grade'}" />
          </group>
        </search>
      </field>
    </record>

    <record id="view_school_student_list" model="ir.ui.view">
      <field name="name">school.student.list</field>
      <field name="model">school.student</field>
      <field name="arch" type="xml">
        <list string="Lista de Estudiantes">
          <field name="name" width="400px" />
          <field name="grade" width="250px" class="me-4"/>
          <field name="birth_date" width="250px" class="me-4" />
          <field name="age" width="100px" class="ms-4"/>
          <field name="write_date" invisible="1" />
        </list>
      </field>
    </record>

    <record id="view_school_student_form" model="ir.ui.view">
      <field name="name">school.student.form</field>
      <field name="model">school.student</field>
      <field name="arch" type="xml">
        <form string="Ficha del Estudiante">
          <sheet>
            <group>
              <group string="Información Personal">
                <field name="name" />
                <field name="birth_date" />
                <field name="age" readonly="1" />
              </group>
              <group string="Información Académica">
                <field name="grade" />
              </group>
            </group>
            <notebook>
              <page string="Notas Adicionales">
                <field name="description" placeholder="Observaciones..." />
              </page>
            </notebook>
          </sheet>
        </form>
      </field>
    </record>

    <record id="action_school_student" model="ir.actions.act_window">
      <field name="name">Estudiantes</field>
      <field name="res_model">school.student</field>
      <field name="view_mode">list,form</field>
      <field name="search_view_id" ref="view_school_student_search" />
    </record>

    <menuitem id="menu_school_root" name="Escuela" sequence="10" />
    <menuitem id="menu_school_students_category" name="Administración" parent="menu_school_root"
      sequence="10" />
    <menuitem id="menu_school_student_action" name="Estudiantes"
      parent="menu_school_students_category" action="action_school_student" sequence="10" />
  </data>
</odoo>